# Jarvis API keys. Copy this file to ".env" and paste your own keys.
# All are FREE. Jarvis rotates through them in order — when one hits its
# rate limit, it automatically falls back to the next, so you get much more
# usable time than any single free tier allows. You only need one to start.

# Groq (primary — fastest). https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras (free, very fast, generous limits). https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# OpenRouter (free models, separate daily budget). https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini (free tier). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# NewsAPI (OPTIONAL — World news already works on free RSS). https://newsapi.org/register
NEWSAPI_KEY=

# YouTube Data API (OPTIONAL — Tech feed has RSS fallback). https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
